# Cache the page briefly in the browser so a refresh/viral spike is absorbed
# client-side. Short max-age keeps redeploys visible within a few minutes; the
# live data comes from /api/well, which has its own long cache.
/
  Cache-Control: public, max-age=300, stale-while-revalidate=86400
/index.html
  Cache-Control: public, max-age=300, stale-while-revalidate=86400
